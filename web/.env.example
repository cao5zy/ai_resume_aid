# Deployment sub-path (default '/' for root deployment).
# Set when deploying to a subdirectory, e.g.: /resume/
# VITE_BASE_URL=/

# API base URL (origin + path prefix).
# Leave empty in development — Vite dev proxy handles routing.
# Set in production, e.g.: http://your-server:3001/api
# VITE_API_BASE_URL=
