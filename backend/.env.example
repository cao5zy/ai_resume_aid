ZHIHU_API_TOKEN=your_zhihu_api_token_here
# DeepSeek API key for fallback when Zhihu API fails after retries (optional)
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Maximum upload file size in MB for PDF uploads (default: 10)
UPLOAD_MAX_SIZE_MB=10
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
# API path prefix for all endpoints (default: /api)
# API_PREFIX=/api
RUST_LOG=info
